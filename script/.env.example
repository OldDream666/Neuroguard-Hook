     1|# NeuroGuard AI Agent - Environment Config
     2|# Copy to .env and fill in your values.
     3|
     4|# X Layer Testnet RPC
     5|RPC_URL=https://testrpc.xlayer.tech
     6|CHAIN_ID=1952
     7|
     8|# AI Agent wallet private key (must match aiAgent in Hook contract)
     9|PRIVATE_KEY=0x_your_private_key_here
    10|
