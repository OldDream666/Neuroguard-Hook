    12|HOOK_ADDRESS=0x595ac52d42D77902dbF4fdD274456409C9CC1080
    13|
    14|# Token to monitor (CoinGecko ID)
    15|# Common: ethereum, bitcoin, solana, dogecoin, pepe, shiba-inu
