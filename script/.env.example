# NeuroGuard AI Agent - Environment Config
# Copy to .env and fill in your values.

# X Layer Testnet RPC
RPC_URL=https://testrpc.xlayer.tech
CHAIN_ID=1952

# AI Agent wallet private key (must match aiAgent in Hook contract)
PRIVATE_KEY=0x_your_private_key_here

# Deployed NeuroGuardHook contract address
HOOK_ADDRESS=0x595ac52d42D77902dbF4fdD274456409C9CC1080

# Token to monitor (OKX instrument ID)
# Common: ETH-USDT, BTC-USDT, SOL-USDT, DOGE-USDT, PEPE-USDT, SHIB-USDT
TOKEN_ID=ETH-USDT

# Optional: OpenAI for LLM-based sentiment
# OPENAI_API_KEY=sk-xxx
